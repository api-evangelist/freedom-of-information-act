    {
      "id": "7648bd73-a73a-40e2-84b2-1c5e1ec42ea4",
      "name": "Agency Submission",
      "description": {
        "content": "Portal-to-agency request submission API (implemented by participating agencies at foia-api.agency.gov).",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "bed3c441-9272-4634-9821-3d3110421b15",
          "name": "Submit a FOIA request to an agency component",
          "request": {
            "name": "Submit a FOIA request to an agency component",
            "description": {
              "content": "Submit a FOIA request from the National FOIA Portal to an agency component. Agencies implement this endpoint at their own host (recommended: `foia-api.agency.gov`).",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "components",
                ":id",
                "requests",
                ""
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<integer>",
                  "key": "id",
                  "description": "(Required) Unique identifier for the agency component."
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": {
              "type": "apikey",
              "apikey": [
                {
                  "key": "key",
                  "value": "FOIA-API-SECRET"
                },
                {
                  "key": "value",
                  "value": "{{apiKey}}"
                },
                {
                  "key": "in",
                  "value": "header"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"version\": \"<string>\",\n  \"request_id\": \"<integer>\",\n  \"agency\": \"<string>\",\n  \"agency_component_name\": \"<string>\",\n  \"request_description\": \"<string>\",\n  \"pdf\": \"<object>\",\n  \"testing\": \"<boolean>\"\n}",
